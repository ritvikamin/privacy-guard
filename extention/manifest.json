{
  "manifest_version": 3,
  "name": "Privacy Guard",
  "version": "1.0",
  "description": "Intercepts and anonymizes PII before it reaches LLMs.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content/interceptor.js"],
      "run_at": "document_idle"
    }
  ]
}